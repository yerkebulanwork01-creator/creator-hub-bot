generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══ Пайдаланушылар ═════════════════════════════════════════
model User {
  id          String   @id @default(cuid())
  telegramId  BigInt   @unique @map("telegram_id")
  firstName   String   @map("first_name")
  lastName    String?  @map("last_name")
  username    String?
  phone       String?
  role        Role     @default(PARTICIPANT)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  participant    Participant?
  adminScans     AttendanceLog[] @relation("ScannedBy")
  notifications  Notification[]

  @@map("users")
}

enum Role {
  PARTICIPANT
  ADMIN
  SUPERADMIN
}

// ═══ Қатысушылар ════════════════════════════════════════════
model Participant {
  id                     String   @id @default(cuid())
  userId                 String   @unique @map("user_id")
  externalRegistrationId String?  @unique @map("external_reg_id")
  cohort                 String?  // поток
  city                   String?
  programName            String?  @map("program_name")
  isLinked               Boolean  @default(false) @map("is_linked")
  createdAt              DateTime @default(now()) @map("created_at")

  user           User              @relation(fields: [userId], references: [id])
  enrollments    Enrollment[]
  attendanceLogs AttendanceLog[]
  pointsLedger   PointsLedger[]
  testResults    TestResult[]
  redemptions    RewardRedemption[]

  @@map("participants")
}

// ═══ Мероприятиелер ═════════════════════════════════════════
model Event {
  id          String    @id @default(cuid())
  title       String
  type        EventType @default(OFFLINE)
  startAt     DateTime  @map("start_at")
  endAt       DateTime  @map("end_at")
  placeName   String?   @map("place_name")
  latitude    Float?
  longitude   Float?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  enrollments    Enrollment[]
  attendanceLogs AttendanceLog[]
  tests          Test[]

  @@map("events")
}

enum EventType {
  ONLINE
  OFFLINE
}

// ═══ Қатысушы + Мероприятие байланысы ═══════════════════════
model Enrollment {
  id            String           @id @default(cuid())
  participantId String           @map("participant_id")
  eventId       String           @map("event_id")
  status        EnrollmentStatus @default(ENROLLED)
  createdAt     DateTime         @default(now()) @map("created_at")

  participant Participant @relation(fields: [participantId], references: [id])
  event       Event       @relation(fields: [eventId], references: [id])

  @@unique([participantId, eventId])
  @@map("enrollments")
}

enum EnrollmentStatus {
  ENROLLED
  CANCELLED
  COMPLETED
}

// ═══ Посещаемость журналы ═══════════════════════════════════
model AttendanceLog {
  id            String           @id @default(cuid())
  participantId String           @map("participant_id")
  eventId       String           @map("event_id")
  action        AttendanceAction
  scannedById   String?          @map("scanned_by_id")
  scannedAt     DateTime         @default(now()) @map("scanned_at")
  qrNonce       String?          @unique @map("qr_nonce")
  source        String           @default("qr_scan")

  participant Participant @relation(fields: [participantId], references: [id])
  event       Event       @relation(fields: [eventId], references: [id])
  scannedBy   User?       @relation("ScannedBy", fields: [scannedById], references: [id])

  @@map("attendance_logs")
}

enum AttendanceAction {
  CHECK_IN
  CHECK_OUT
}

// ═══ Баллдар (проводка журналы) ═════════════════════════════
model PointsLedger {
  id            String   @id @default(cuid())
  participantId String   @map("participant_id")
  reason        String
  pointsDelta   Int      @map("points_delta")
  sourceType    String?  @map("source_type")
  sourceId      String?  @map("source_id")
  createdAt     DateTime @default(now()) @map("created_at")

  participant Participant @relation(fields: [participantId], references: [id])

  @@map("points_ledger")
}

// ═══ Тесттер ════════════════════════════════════════════════
model Test {
  id        String   @id @default(cuid())
  eventId   String   @map("event_id")
  title     String
  dueAt     DateTime @map("due_at")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  event   Event        @relation(fields: [eventId], references: [id])
  results TestResult[]

  @@map("tests")
}

model TestResult {
  id            String   @id @default(cuid())
  participantId String   @map("participant_id")
  testId        String   @map("test_id")
  score         Int
  submittedAt   DateTime @default(now()) @map("submitted_at")

  participant Participant @relation(fields: [participantId], references: [id])
  test        Test        @relation(fields: [testId], references: [id])

  @@unique([participantId, testId])
  @@map("test_results")
}

// ═══ Мерч магазин ═══════════════════════════════════════════
model Reward {
  id         String   @id @default(cuid())
  title      String
  pointsCost Int      @map("points_cost")
  stock      Int      @default(0)
  imageUrl   String?  @map("image_url")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  redemptions RewardRedemption[]

  @@map("rewards")
}

model RewardRedemption {
  id            String           @id @default(cuid())
  participantId String           @map("participant_id")
  rewardId      String           @map("reward_id")
  status        RedemptionStatus @default(PENDING)
  createdAt     DateTime         @default(now()) @map("created_at")

  participant Participant @relation(fields: [participantId], references: [id])
  reward      Reward      @relation(fields: [rewardId], references: [id])

  @@map("reward_redemptions")
}

enum RedemptionStatus {
  PENDING
  ISSUED
  CANCELLED
}

// ═══ Хабарламалар ═══════════════════════════════════════════
model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  message   String
  sentAt    DateTime @default(now()) @map("sent_at")
  isRead    Boolean  @default(false) @map("is_read")

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}
